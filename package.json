{
  "name": "hospital-warm-management",
  "version": "1.0.0",
  "scripts": {
    "dev": "webpack serve",
    "build": "npm run typecheck && npm run lint && webpack --mode production",
    "typecheck": "tsc --noEmit",
    "lint": "NODE_OPTIONS='--no-deprecation' eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\"",
    "audit": "npm install --package-lock-only --registry=https://mirrors.cloud.tencent.com/npm && npm audit --audit-level=moderate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test": "npm run typecheck && npm run lint && npm run test:e2e",
    "prepare": "husky install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "date-fns": "^2.30.0",
    "framer-motion": "^11.16.1",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "recharts": "^2.10.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@babel/preset-react": "^7.23.5",
    "@babel/preset-typescript": "^7.23.5",
    "@playwright/test": "^1.59.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.8.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^4.3.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "html-webpack-plugin": "^5.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.31",
    "postcss-loader": "^7.3.3",
    "prettier": "^3.8.3",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.3"
  }
}
